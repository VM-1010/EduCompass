<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@menulayout.css" xmlns="http://javafx.com/javafx/21.0.8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.ui.AdminLoginController">
   <children>
      <VBox alignment="CENTER" prefHeight="271.0" prefWidth="600.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="label" text="Authentication required Please enter admin password" textAlignment="CENTER" wrappingWidth="500.0" VBox.vgrow="ALWAYS" />
            <ImageView fitHeight="115.0" fitWidth="136.0" pickOnBounds="true" preserveRatio="true">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
               <image>
                  <Image url="@key.png" />
               </image>
            </ImageView>
         </children>
      </VBox>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #56ff76;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <PasswordField fx:id="pass" prefHeight="45.0" prefWidth="298.0" promptText="Enter your admin password" styleClass="inputfield" />
            <Button fx:id="submit" mnemonicParsing="false" onAction="#adminpressedlogin" styleClass="loginbutton" text="Login" textAlignment="CENTER" HBox.hgrow="ALWAYS">
